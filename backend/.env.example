# ─── LLM Provider ────────────────────────────────────────────────────────────
# Choose one: claude | openai | gemini | minimax
LLM_PROVIDER=claude

# Optional: override the default model for the chosen provider
# Defaults: claude-sonnet-4-5 | gpt-4o | gemini-1.5-pro | MiniMax-Text-01
LLM_MODEL=

# ─── API Keys (only the one matching LLM_PROVIDER is required) ───────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here
GOOGLE_API_KEY=your-google-api-key-here
MINIMAX_API_KEY=your-minimax-api-key-here
MINIMAX_GROUP_ID=your-minimax-group-id-here
